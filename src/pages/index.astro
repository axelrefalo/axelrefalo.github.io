---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <div class="container">
    <section id="home">
      <div class="hero-photo">
        <img src="/profil.png" alt="Axel Refalo" />
      </div>
      <div>
        <div class="hero-name">Axel Refalo</div>
        <div class="hero-role">Developer · Montréal</div>
        <div class="hero-bio">
          I build thoughtful things for the web — with clean code and an eye for detail.
          Currently open to new opportunities.
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .container {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 40px;
  }

  #home {
    padding: 56px 0;
    display: flex;
    gap: 40px;
    align-items: flex-start;
  }

  .hero-photo {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    background: #e8e8e8;
    flex-shrink: 0;
    overflow: hidden;
  }

  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-name {
    font-size: 30px;
    font-weight: 700;
    color: #111;
    line-height: 1.2;
    margin-bottom: 8px;
  }

  .hero-role {
    font-size: 14px;
    color: #888;
    margin-bottom: 16px;
    font-style: italic;
  }

  .hero-bio {
    font-size: 15px;
    color: #333;
    line-height: 1.8;
    max-width: 520px;
  }

  @media (max-width: 600px) {
    .container { padding: 0 20px; }
    #home { flex-direction: column; gap: 24px; }
  }
</style>
