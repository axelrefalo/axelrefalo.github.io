---
import BaseLayout from "../layouts/BaseLayout.astro";

// ── HERO ────────────────────────────────────────────────────────────────────
const hero = {
  photo: "/profil.png",
  name: "Axel Refalo",
  roles: [
    "M.Sc. in Automation Engineering from ETS",
    "B.Eng. and M.Eng. in Mechanical Engineering from UTBM",
  ],
  bio: [
    `Master's student in Automation, I am currently pursuing my master's thesis at the <strong>Control and Robotics Laboratory</strong> of <strong>École de technologie supérieure</strong>, under the supervision of Prof. <strong>Ilian Bonev</strong> and Prof. <strong>Clément Gosselin</strong>. My research explores serial manipulator morphologies and their implications in the kinematics of the arm.`,
    `Throughout my master's, I have been involved in a few other research projects ranging from satellite navigation to materials engineering. I currently contributing to the CHIP project at <strong>McGill Bioresources Lab</strong>, to develop an automatic platform for plant growth data collection, alongside <strong>Mohamed Debbagh</strong>.`,
    `I also have hands-on experience in robotics, having developed two microscopic inspection robots for <strong>Canon Production Printing</strong> in the Netherlands under the supervision of Dr. <strong>Karel Kneychen</strong>, as well as personal robotics projects I develop in my spare time.`,
  ],
  links: [
    { label: "CV",       href: "/cv.pdf",                                              icon: "fa-regular fa-file",       type: "pdf"      },
    { label: "LinkedIn", href: "https://www.linkedin.com/in/axel-refalo-3b4838228/",   icon: "fa-brands fa-linkedin-in",  external: true   },
    { label: "GitHub",   href: "https://github.com/axelrefalo",                        icon: "fa-brands fa-github",       external: true   },
    { label: "GrabCAD",  href: "https://grabcad.com/axel.refalo-1",                    icon: "fa-solid fa-cube",          external: true   },
    { label: "Email",    href: "mailto:axel.refalo@gmail.com",                         icon: "fa-regular fa-envelope"                     },
  ],
};

// ── PUBLICATIONS ─────────────────────────────────────────────────────────────
const publications = [
  {
    title:   "Singularity Analysis of ABB's GoFa 5 Robot Arm",
    authors: "Refalo, A., Bonev, I., and Gosselin, C.",
    venue:   "IEEE ICRA 2026",
    media:   { type: "image", src: "/media/publications/singularity-analysis.png", zoomable: true },
    link:    { href: "/media/publications/icra2026-poster.pdf", type: "pdf" },
  },
  {
    title:   "An Affordable and Open-Source Gantry Framework for Capturing High Resolution Spatiotemporal Plant Growth Data",
    authors: "Debbagh, M., Refalo, A., et al.",
    venue:   "In preparation",
    media:   { type: "video", src: "/media/publications/plant-growth.mov", dim: true },
    link:    { href: "https://github.com/Controlled-Hydroponics-Imaging-Platform", type: "external" },
  },
];

// ── COURSEWORK ───────────────────────────────────────────────────────────────
const coursework = [
  {
    title:       "Applied Machine Learning",
    institution: "McGill University",
    year:        2025,
    media:       { type: "image", src: "/media/coursework/applied-ml.gif", zoomable: true },
    link:        { href: "https://github.com/axelrefalo/applied-machine-learning-w2025", type: "external" },
  },
  {
    title:       "Applied Robotics",
    institution: "McGill University",
    year:        2024,
    media:       { type: "video", src: "/media/coursework/applied-robotics.mp4" },
    link:        { href: "https://github.com/axelrefalo/applied-robotics-f2024", type: "external" },
  },
  {
    title:       "Model Reference Adaptive Control Quadrotor",
    institution: "École de Technologie Supérieure",
    year:        2024,
    media:       { type: "video", src: "/media/coursework/mrac-quadrotor.mp4" },
  },
];

// ── PROJECTS ─────────────────────────────────────────────────────────────────
const projects = [
  {
    title: "Cable-Driven Plotter",
    year:  2026,
    media: { type: "video", src: "/media/projects/cable-driven-plotter.mov", speed: 4 },
  },
  {
    title: "3-DOF Manipulator",
    year:  2024,
    media: { type: "video", src: "/media/projects/3dof-manipulator.mov", speed: 2 },
  },
];
---

<BaseLayout>
  <div class="container">

    <!-- HERO -->
    <section id="home">
      <div class="hero-top">
        <div class="hero-photo">
          <img src={hero.photo} alt={hero.name} />
        </div>
        <div>
          <div class="hero-name">{hero.name}</div>
          {hero.roles.map((r) => <div class="hero-role">{r}</div>)}
        </div>
      </div>
      <div class="hero-footer">
        {hero.bio.map((para) => <p class="hero-bio" set:html={para} />)}
        <div class="contact-links contact-links-center">
          {hero.links.map((link) => (
            <a
              class={`contact-link${link.type === "pdf" ? " pdf-link" : ""}`}
              href={link.href}
              target={link.external ? "_blank" : undefined}
              title={link.label}
            >
              <i class={link.icon}></i>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- PUBLICATIONS -->
    <section>
      <div class="section-label">Publications</div>
      <div class="card-list">
        {publications.map((item) => (
          <div class="card-item">
            <div class="card-media">
              {item.media.type === "image" ? (
                <img src={item.media.src} alt={item.title} class={item.media.zoomable ? "zoomable" : ""} />
              ) : (
                <video
                  src={item.media.src}
                  autoplay muted loop playsinline
                  class={`zoomable${item.media.dim ? " dim" : ""}`}
                  data-speed={item.media.speed}
                ></video>
              )}
            </div>
            <div class="card-content">
              <div class="card-title">
                {item.link ? (
                  item.link.type === "pdf" ? (
                    <a href={item.link.href} class="pdf-link"><strong>{item.title}</strong></a>
                  ) : (
                    <a href={item.link.href} target="_blank"><strong>{item.title}</strong></a>
                  )
                ) : (
                  <strong>{item.title}</strong>
                )}
              </div>
              {item.authors && <div class="card-authors">{item.authors}</div>}
              <div class="card-venue">{item.venue}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- COURSEWORK -->
    <section>
      <div class="section-label">Coursework</div>
      <div class="card-list">
        {coursework.map((item) => (
          <div class="card-item">
            <div class="card-media">
              {item.media.type === "image" ? (
                <img src={item.media.src} alt={item.title} class={item.media.zoomable ? "zoomable" : ""} />
              ) : (
                <video
                  src={item.media.src}
                  autoplay muted loop playsinline
                  class={`zoomable${item.media.dim ? " dim" : ""}`}
                  data-speed={item.media.speed}
                ></video>
              )}
            </div>
            <div class="card-content">
              <div class="card-title">
                {item.link ? (
                  <a href={item.link.href} target="_blank"><strong>{item.title}</strong></a>
                ) : (
                  <strong>{item.title}</strong>
                )}
              </div>
              <div class="card-venue">{item.institution}</div>
              <div class="card-venue">{item.year}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- PROJECTS -->
    <section>
      <div class="section-label">Projects</div>
      <div class="card-list">
        {projects.map((item) => (
          <div class="card-item">
            <div class="card-media">
              {item.media.type === "image" ? (
                <img src={item.media.src} alt={item.title} class={item.media.zoomable ? "zoomable" : ""} />
              ) : (
                <video
                  src={item.media.src}
                  autoplay muted loop playsinline
                  class={`zoomable${item.media.dim ? " dim" : ""}`}
                  data-speed={item.media.speed}
                ></video>
              )}
            </div>
            <div class="card-content">
              <div class="card-title">
                {item.link ? (
                  <a href={item.link.href} target="_blank"><strong>{item.title}</strong></a>
                ) : (
                  <strong>{item.title}</strong>
                )}
              </div>
              <div class="card-venue">{item.year}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

  </div>

  <div id="lightbox" class="lightbox">
    <img id="lightbox-img" src="" alt="" />
    <video id="lightbox-video" src="" autoplay muted loop playsinline></video>
  </div>

  <div id="cv-modal" class="cv-modal">
    <div class="cv-modal-inner">
      <iframe id="cv-frame" src="" title="CV"></iframe>
    </div>
  </div>
</BaseLayout>

<style>
  .container {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 40px;
  }

  section {
    padding: 20px 0;
    border-bottom: 1px solid #e8e8e8;
  }

  section:last-child {
    border-bottom: none;
  }

  /* ── HERO ── */
  #home {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }

  .hero-top {
    display: flex;
    gap: 40px;
    align-items: center;
  }

  .hero-photo {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    background: #e8e8e8;
    flex-shrink: 0;
    overflow: hidden;
  }

  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-name {
    font-size: 30px;
    font-weight: 700;
    color: #111;
    line-height: 1.2;
    margin-bottom: 6px;
  }

  .hero-role {
    font-size: 15px;
    color: #888;
    font-style: italic;
  }

  .hero-footer {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .hero-bio {
    font-size: 15px;
    color: #333;
    line-height: 1.7;
    text-align: justify;
  }

  .hero-bio + .hero-bio {
    margin-top: 6px;
  }

  /* ── SECTION LABEL ── */
  .section-label {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #aaa;
    margin-bottom: 28px;
  }

  /* ── CONTACT LINKS ── */
  .contact-links {
    display: flex;
    gap: 56px;
    flex-wrap: wrap;
  }

  .contact-links-center {
    justify-content: center;
  }

  .contact-link {
    font-size: 13px;
    color: #111;
    text-decoration: none;
    border-bottom: 1px solid #111;
    padding-bottom: 1px;
    transition: opacity 0.15s;
  }

  .contact-link:hover { opacity: 0.5; }

  /* ── CARDS ── */
  .card-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .card-item {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .card-media {
    width: 200px;
    height: 130px;
    flex-shrink: 0;
    background: #f0f0f0;
    overflow: hidden;
    border-radius: 4px;
  }

  .card-media img,
  .card-media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-media video.dim {
    filter: brightness(0.6);
  }

  .card-media img.zoomable {
    cursor: zoom-in;
  }

  .card-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: 4px;
  }

  .card-title {
    font-size: 15px;
    color: #111;
    line-height: 1.4;
  }

  .card-title a {
    color: inherit;
    text-decoration: none;
  }

  .card-authors {
    font-size: 12px;
    color: #999;
  }

  .card-venue {
    font-size: 13px;
    color: #888;
  }

  /* ── LIGHTBOX ── */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    z-index: 100;
    align-items: center;
    justify-content: center;
    cursor: zoom-out;
  }

  .lightbox.open { display: flex; }

  .lightbox img,
  .lightbox video {
    max-width: 80vw;
    max-height: 80vh;
    border-radius: 4px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.4);
    object-fit: contain;
  }

  #lightbox-video { display: none; }

  /* ── PDF MODAL ── */
  .cv-modal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    z-index: 100;
    align-items: center;
    justify-content: center;
    cursor: zoom-out;
  }

  .cv-modal.open { display: flex; }

  .cv-modal-inner {
    width: 75vw;
    height: 85vh;
    cursor: default;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0,0,0,0.4);
  }

  .cv-modal-inner iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  @media (max-width: 600px) {
    .container { padding: 0 20px; }
    #home { flex-direction: column; gap: 24px; }
    .card-item { flex-direction: column; }
    .card-media { width: 100%; height: 160px; }
  }
</style>

<script>
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const lightboxVideo = document.getElementById('lightbox-video');

  document.querySelectorAll('img.zoomable').forEach(img => {
    img.addEventListener('click', () => {
      lightboxImg.src = img.src;
      lightboxImg.alt = img.alt;
      lightboxImg.style.display = 'block';
      lightboxVideo.style.display = 'none';
      lightboxVideo.src = '';
      lightbox.classList.add('open');
    });
  });

  document.querySelectorAll('video.zoomable').forEach(video => {
    if (video.dataset.speed) video.playbackRate = parseFloat(video.dataset.speed);
    video.addEventListener('click', () => {
      lightboxVideo.src = video.src;
      lightboxVideo.style.display = 'block';
      lightboxImg.style.display = 'none';
      lightboxImg.src = '';
      lightbox.classList.add('open');
    });
  });

  lightbox.addEventListener('click', () => {
    lightbox.classList.remove('open');
    lightboxVideo.src = '';
  });

  const cvModal = document.getElementById('cv-modal');
  const cvFrame = document.getElementById('cv-frame');

  document.querySelectorAll('a.pdf-link').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      cvFrame.src = link.href;
      cvModal.classList.add('open');
    });
  });

  cvModal.addEventListener('click', (e) => {
    if (!e.target.closest('.cv-modal-inner')) {
      cvModal.classList.remove('open');
      cvFrame.src = '';
    }
  });
</script>
