---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
projects.sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));
---

<BaseLayout title="Projects — Axel Refalo">
  <div class="container">
    <section>
      <div class="section-label">Selected work</div>
      <div class="project-list">
        {projects.map((project, i) => (
          <>
            <div class="project-item">
              <div>
                <div class="project-name">
                  <a href={`/projects/${project.id}`}>{project.data.title}</a>
                </div>
                <div class="project-desc">{project.data.description}</div>
              </div>
              <div class="project-year">{project.data.year}</div>
            </div>
            {i < projects.length - 1 && <hr class="divider" />}
          </>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .container {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 40px;
  }

  section {
    padding: 56px 0;
  }

  .section-label {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #aaa;
    margin-bottom: 28px;
  }

  .project-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .project-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 20px;
  }

  .project-name {
    font-size: 16px;
    font-weight: 700;
    color: #111;
    margin-bottom: 4px;
  }

  .project-name a {
    color: inherit;
    text-decoration: none;
  }

  .project-name a:hover {
    border-bottom: 1px solid #111;
  }

  .project-desc {
    font-size: 13px;
    color: #888;
    font-style: italic;
  }

  .project-year {
    font-size: 12px;
    color: #bbb;
    flex-shrink: 0;
  }

  .divider {
    border: none;
    border-top: 0.5px solid #eee;
  }

  @media (max-width: 600px) {
    .container { padding: 0 20px; }
  }
</style>
