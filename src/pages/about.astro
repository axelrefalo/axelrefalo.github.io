---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About — Axel Refalo">
  <div class="container">

    <section>
      <div class="section-label">About</div>
      <div class="about-text">
        <p>
          I'm a robotics engineer and researcher based in Montréal, currently pursuing a
          Master's in Automation Engineering at ÉTS within the CoRo lab, alongside an
          exchange program in Computer Science at McGill. My thesis focuses on kinematic
          singularities and path planning for serial robot arms.
        </p>
        <p>
          I hold a Master's in Mechanical Engineering from UTBM (France), with a
          specialization in Mechatronics. My background spans mechanics, electronics,
          control systems, and software — I enjoy working across the full stack of a
          robotic system, from mechanical design to the algorithms that make it move.
        </p>
        <p>
          Outside research, I build things for the pleasure of it: fluid simulators,
          puzzle solvers, FEM tools. I'm driven by challenge and curiosity — whether
          it's a complex kinematic problem, a hackathon, or a chess endgame.
        </p>
        <p>
          I've traveled and studied across Canada, France, Italy, the Netherlands and
          Spain, which shaped both my engineering perspective and my love for languages.
          I speak French, English and Italian fluently.
        </p>
      </div>
    </section>

    <section>
      <div class="section-label">Get in touch</div>
      <div class="contact-links">
        <a class="contact-link" href="mailto:axel.refalo@gmail.com">Email</a>
        <a class="contact-link" href="https://github.com/axelrefalo" target="_blank">GitHub</a>
        <a class="contact-link" href="https://www.linkedin.com/in/axel-refalo-3b4838228/" target="_blank">LinkedIn</a>
        <a class="contact-link" href="https://grabcad.com/axel.refalo-1" target="_blank">GrabCAD</a>
        <a class="contact-link" href="/cv.pdf" target="_blank">CV</a>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  .container {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 40px;
  }

  section {
    padding: 56px 0;
    border-bottom: 1px solid #e8e8e8;
  }

  section:last-child {
    border-bottom: none;
  }

  .section-label {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #aaa;
    margin-bottom: 28px;
  }

  .about-text {
    font-size: 15px;
    color: #333;
    line-height: 1.85;
    max-width: 600px;
  }

  .about-text p + p {
    margin-top: 16px;
  }

  .contact-links {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  .contact-link {
    font-size: 13px;
    color: #111;
    text-decoration: none;
    border-bottom: 1px solid #111;
    padding-bottom: 1px;
    transition: opacity 0.15s;
  }

  .contact-link:hover { opacity: 0.5; }

  @media (max-width: 600px) {
    .container { padding: 0 20px; }
  }
</style>
