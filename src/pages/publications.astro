---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Publications — Axel Refalo">
  <div class="container">
    <section>
      <div class="section-label">Publications</div>
      <div class="pub-list">

        <div class="pub-item">
          <div>
            <div class="pub-title">
              Singularity Analysis of ABB's GoFa 5 Robot Arm
            </div>
            <div class="pub-authors">Refalo, A., Bonev, I., and Gosselin, C.</div>
            <div class="pub-venue">IEEE International Conference on Robotics and Automation (ICRA) — Vienna, 2026</div>
          </div>
          <div class="pub-year">2026</div>
        </div>
        <hr class="divider" />

        <div class="pub-item">
          <div>
            <div class="pub-title pub-inprep">
              An Affordable and Open-Source Gantry Framework for Capturing High Resolution Spatiotemporal Plant Growth Data
            </div>
            <div class="pub-authors">Debbagh, M., Refalo, A., et al.</div>
            <div class="pub-venue">In preparation</div>
          </div>
          <div class="pub-year">2025</div>
        </div>

      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .container {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 40px;
  }

  section {
    padding: 56px 0;
  }

  .section-label {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #aaa;
    margin-bottom: 28px;
  }

  .pub-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .pub-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 20px;
  }

  .pub-title {
    font-size: 16px;
    font-weight: 400;
    color: #111;
    margin-bottom: 4px;
    font-style: italic;
  }

  .pub-title a {
    color: inherit;
    text-decoration: none;
  }

  .pub-title a:hover {
    border-bottom: 1px solid #111;
  }

  .pub-venue {
    font-size: 13px;
    color: #888;
  }

  .pub-authors {
    font-size: 12px;
    color: #999;
    margin-bottom: 3px;
  }

  .pub-inprep {
    color: #888;
  }

  .pub-year {
    font-size: 12px;
    color: #bbb;
    flex-shrink: 0;
  }

  .divider {
    border: none;
    border-top: 0.5px solid #eee;
  }

  @media (max-width: 600px) {
    .container { padding: 0 20px; }
  }
</style>
