---
interface Props {
  title?: string;
}
const { title = "Axel Refalo" } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{title}</title>
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #fff;
      color: #111;
      font-family: 'Libre Baskerville', Georgia, serif;
      min-height: 100vh;
    }

    nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 40px;
      border-bottom: 1px solid #e8e8e8;
      position: sticky;
      top: 0;
      background: #fff;
      z-index: 10;
    }

    .nav-logo {
      font-size: 15px;
      font-weight: 700;
      letter-spacing: 0.5px;
      color: #111;
      text-decoration: none;
    }

    .nav-links {
      display: flex;
      gap: 32px;
      list-style: none;
    }

    .nav-links a {
      font-size: 13px;
      color: #666;
      text-decoration: none;
      font-family: 'Libre Baskerville', Georgia, serif;
      transition: color 0.15s;
    }

    .nav-links a:hover,
    .nav-links a.active {
      color: #111;
    }

    footer {
      padding: 24px 40px;
      font-size: 11px;
      color: #bbb;
      font-style: italic;
      max-width: 780px;
      margin: 0 auto;
    }

    @media (max-width: 600px) {
      nav { padding: 14px 20px; flex-direction: column; gap: 12px; }
      .nav-links { gap: 18px; }
      footer { padding: 20px; }
    }
  </style>
</head>
<body>

  <nav>
    <a class="nav-logo" href="/">Axel Refalo</a>
    <ul class="nav-links">
      <li><a href="/" class={path === "/" ? "active" : ""}>Home</a></li>
      <li><a href="/projects" class={path.startsWith("/projects") ? "active" : ""}>Projects</a></li>
      <li><a href="/publications" class={path === "/publications" ? "active" : ""}>Publications</a></li>
      <li><a href="/about" class={path === "/about" ? "active" : ""}>About</a></li>
      <li><a href="/contact" class={path === "/contact" ? "active" : ""}>Contact</a></li>
    </ul>
  </nav>

  <slot />

  <footer>© 2025 Axel Refalo — Montréal, QC</footer>

</body>
</html>
