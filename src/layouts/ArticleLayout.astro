---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  date?: string;
  cover?: string;
  description?: string;
}

const { title, date, cover, description } = Astro.props;
---

<BaseLayout title={`${title} — Axel Refalo`}>
  <article class="article-wrapper">

    <header class="article-header">
      {date && <div class="article-date">{date}</div>}
      <h1 class="article-title">{title}</h1>
      {description && <p class="article-description">{description}</p>}
    </header>

    {cover && (
      <div class="article-cover">
        <img src={cover} alt={title} />
      </div>
    )}

    <div class="article-body">
      <slot />
    </div>

  </article>
</BaseLayout>

<style>
  .article-wrapper {
    max-width: 680px;
    margin: 0 auto;
    padding: 56px 40px 80px;
  }

  .article-header {
    margin-bottom: 40px;
  }

  .article-date {
    font-size: 12px;
    color: #aaa;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .article-title {
    font-size: 36px;
    font-weight: 700;
    line-height: 1.25;
    color: #111;
    margin-bottom: 16px;
  }

  .article-description {
    font-size: 18px;
    color: #888;
    font-style: italic;
    line-height: 1.6;
  }

  .article-cover {
    margin-bottom: 48px;
    border-radius: 4px;
    overflow: hidden;
  }

  .article-cover img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Corps de l'article ── */
  .article-body {
    font-size: 17px;
    line-height: 1.85;
    color: #222;
  }

  .article-body :global(h2) {
    font-size: 24px;
    font-weight: 700;
    color: #111;
    margin: 48px 0 16px;
  }

  .article-body :global(h3) {
    font-size: 19px;
    font-weight: 700;
    color: #111;
    margin: 36px 0 12px;
  }

  .article-body :global(p) {
    margin-bottom: 24px;
  }

  .article-body :global(a) {
    color: #111;
    border-bottom: 1px solid #111;
    text-decoration: none;
  }

  .article-body :global(a:hover) {
    opacity: 0.5;
  }

  .article-body :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 32px auto;
    border-radius: 4px;
  }

  .article-body :global(blockquote) {
    border-left: 3px solid #e8e8e8;
    padding-left: 20px;
    margin: 32px 0;
    color: #666;
    font-style: italic;
  }

  .article-body :global(code) {
    font-family: 'Courier New', monospace;
    font-size: 14px;
    background: #f5f5f5;
    padding: 2px 6px;
    border-radius: 3px;
  }

  .article-body :global(pre) {
    background: #f5f5f5;
    padding: 20px;
    border-radius: 4px;
    overflow-x: auto;
    margin: 32px 0;
  }

  .article-body :global(pre code) {
    background: none;
    padding: 0;
    font-size: 13px;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    padding-left: 24px;
    margin-bottom: 24px;
  }

  .article-body :global(li) {
    margin-bottom: 8px;
  }

  /* KaTeX display math */
  .article-body :global(.katex-display) {
    margin: 32px 0;
    overflow-x: auto;
    overflow-y: visible;
    padding: 4px 0;
  }

  @media (max-width: 600px) {
    .article-wrapper { padding: 32px 20px 60px; }
    .article-title { font-size: 26px; }
  }
</style>
